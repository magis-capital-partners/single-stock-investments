{
  "schema_version": "1.1",
  "model_ladder": {
    "notes": "Cheap fast model by default; frontier reserved for judgment-heavy lanes: brand-new deep dives (which include the Milly adversarial pass) and IC chair synthesis. Escalation keys match llm_call_gate.resolve_model.",
    "default_model": "composer-2.5",
    "frontier_model": "claude-sonnet-5-thinking-high",
    "consumers": {
      "marvin_research": {
        "frontier_reasons": [
          "no_deep_dive",
          "onboard_pending",
          "batch_onboard_pending"
        ]
      },
      "investment_committee": {
        "frontier_task_ids": ["chair-synthesis"]
      },
      "vicki_ir": {},
      "ci_autofix": {}
    }
  },
  "default": {
    "daily_repo_limit": 4,
    "per_subject_daily_limit": 1,
    "duplicate_evidence_block": true,
    "cooldown_hours": 0
  },
  "consumers": {
    "marvin_research": {
      "daily_repo_limit": 4,
      "per_subject_daily_limit": 2,
      "duplicate_evidence_block": true,
      "cooldown_hours": 24,
      "allowed_reasons": [
        "manual_material_change",
        "new_documents",
        "new_valuation_news",
        "no_deep_dive",
        "onboard_pending",
        "batch_onboard_pending",
        "evidence_gap_ready"
      ]
    },
    "investment_committee": {
      "daily_repo_limit": 40,
      "per_subject_daily_limit": 1,
      "duplicate_evidence_block": true,
      "cooldown_hours": 0,
      "baseline_calls_per_ticker": 5,
      "maximum_calls_per_ticker": 9
    },
    "vicki_ir": {
      "daily_repo_limit": 2,
      "per_subject_daily_limit": 1,
      "duplicate_evidence_block": true,
      "cooldown_hours": 72,
      "allowed_reasons": ["ir_gap", "adapter_failed", "manual_override"]
    },
    "ci_autofix": {
      "daily_repo_limit": 2,
      "per_subject_daily_limit": 1,
      "duplicate_evidence_block": true,
      "cooldown_hours": 168,
      "minimum_repeat_count": 2,
      "maximum_failed_jobs": 2
    }
  }
}
