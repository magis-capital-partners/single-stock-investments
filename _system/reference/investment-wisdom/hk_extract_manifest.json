{
  "version": 1,
  "description": "Maps hk_pdfs vault text files to in-repo horizon-kinetics extracts. refresh_hk_extracts.py uses vault_globs under book/build/text/.",
  "extracts": [
    {
      "dest": "HK-Q1-2025-Commentary-extract.txt",
      "vault_globs": ["*Q1*2025*Commentary*", "*Q1-2025-Horizon-Kinetics-Commentary*"],
      "topic": "Q1 2025 Market Commentary (Apr 2025)"
    },
    {
      "dest": "HK-Q3-2025-Commentary-extract.txt",
      "vault_globs": ["*Q3*2025*Commentary*", "*Q3-2025-Horizon-Kinetics-Commentary*"],
      "topic": "Q3 2025 Market Commentary (Oct 2025)"
    },
    {
      "dest": "HK-Q1-2026-Commentary-extract.txt",
      "vault_globs": ["*Q1*2026*Commentary*", "*Q1-2026-Horizon-Kinetics-Commentary*"],
      "topic": "Q1 2026 Market Commentary (Apr 2026)"
    },
    {
      "dest": "Stahl-Equity-Yield-Curve-extract.txt",
      "vault_globs": ["*Compilation-of-Murray-Stahl*", "*830350067*"],
      "topic": "Compilation of Murray Stahl's Writings (equity yield curve)"
    },
    {
      "dest": "Stahl-Worth-The-Time-Predictive-Attributes-extract.txt",
      "vault_globs": ["*Worth*Time*", "*Predictive*Attributes*", "*Value*Investor*Insight*Feb*2024*"],
      "topic": "Worth The Time interview — predictive attributes (Feb 2024)"
    }
  ]
}
