                <article id="post-2106" class="post-2106 post type-post status-publish format-standard has-post-thumbnail hentry category-articles">
                
                <header class="content-primary__header">
                    <div class="container">
                        <h1 class="content-primary__title">Block Presenting at Kase Learning Conference in New York (December 3, 2018)</h1>
                    </div>
