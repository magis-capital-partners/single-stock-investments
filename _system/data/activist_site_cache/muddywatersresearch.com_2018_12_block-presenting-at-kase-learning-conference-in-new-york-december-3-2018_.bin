			.report-download-consent {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
    cursor: pointer;
    color: #ffffff;
    line-height: 1.5;
    text-align: left;
}

.report-download-consent span{
    display:block;
    text-align:left;
}

.report-download-consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 4px;
    accent-color: #9ca3af;
}

.button-download.is-disabled {
    pointer-events: none;
    opacity: 0.5;
    cursor: not-allowed;
}		</style>
