ivacy_Statement.pdf" color="secondary1" target="_blank" class="sc-gEvEer dNokUJ  secondary1 Always  Varysize" tabindex="0">Online Privacy Statement</a> <!-- -->and our<!-- --> <a rel="noreferrer" href="https://www.deshaw.com/assets/important-disclosure/Terms_and_Conditions_of_Use.pdf" color="secondary1" target="_blank" class="sc-gEvEer dNokUJ  secondary1 Always  Varysize" tabindex="0">Terms of Use</a>, which include a class action waiver and an arbitration provision. Clicking “Accept All” means you consent to our use of cookies and similar tracking technologies, such as analytics cookies provided by third-party companies, which help us understand how our website is used. Clicking “Decline All” means you prevent us from using non-essential cookies or other similar tracking technologies on our website; however, we will continue to use essential cookies for the core functions of our website, including security.</div><div class="sc-kpDqfm jnDBBH"><button class="sc-dAlyuH bYmxqf">Accept All</button><button class="sc-dAlyuH eZEfGd">Decline All</button></div></section></div><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"routes":{"home":"/","whoWeAre":"/who-we-are","whatWeDo":"/what-we-do","careers":"/careers","investorLogin":"/irweb","news":"/news","library":"/library","contact":"/contact","whoWeAreIntro":"/who-we-are","leadership":"/who-we-are/leadership","founder":"/who-we-are/founder","corePrinciples":"/who-we-are/core-principles","ourPeople":"/who-we-are/our-people","whatWeDoIntro":"/what-we-do","investmentManagement":"/what-we-do/investment-management","technology":"/what-we-do/technology-development","managingRisk":"/what-we-do/risk-management","entrepreneurship":"/what-we-do/entrepreneurship","industryLeadership":"/what-we-do/industry-leadership","careersIntro":"/careers","careerDevelopment":"/careers/career-development","chooseYourPath":"/careers/choose-your-path","interviewing":"/careers/interviewing","benefits":"/careers/benefits","internships":"/careers/internships"},"capabilities":[{"icon":"/img/icons/icon-hedge-fund.svg","title":"Hedge Funds","content":"Our hedge funds consist primarily of multi-strategy vehicles that seek to offer attractive risk-adjusted returns, generally with low correlation to traditional assets."},{"icon":"/img/icons/icon-privates.svg","title":"Privates","content":"Our private markets investment activities pursue a range of opportunities, including in private credit, venture and growth equity, and capital solutions for financial institutions and corporates."},{"icon":"/img/icons/icon-active-equity.svg","title":"Active Equity ","content":"Our actively managed equity strategies pursue attractive long-term excess returns relative to common equity benchmarks, deploying a systematic, risk-aware approach to stock selection."},{"icon":"/img/icons/icon-multi-asset.svg","title":"Multi-Asset Class","content":"Our multi-asset class strategies harness the firm’s investment capabilities to pursue forecast-driven, diversified portfolios across liquid global asset classes."}]},"__N_SSG":true},"page":"/what-we-do/[[...slug]]","query":{"slug":["entrepreneurship"]},"buildId":"QiKE25N6-kjoBgGag7Qon","isFallback":false,"gsp":true,"locale":"en","locales":["en"],"defaultLocale":"en","scriptLoader":[]}</script></body></html>