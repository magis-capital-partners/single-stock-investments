humbnailWrapper"><div class="sc-hCPjZK gAaMvB border "></div><img alt="D. E. Shaw employee." src="/img/video-images/icons/de-shaw-657780793.1de91f79fa.jpg" class="sc-fXSgeo lgwBdZ thumbnail"/><div class="sc-Nxspf gyQLGP playButton"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" style="margin-left:-2px"><polygon points="4 0 36 20 4 40 4 0"></polygon></svg></div></div></button><button data-video-id="657781310.6e57cd6aa8" class="sc-fjvvzt keAAAN VideoListThumbnail  " aria-label="play video: D. E. Shaw employee."><div class="sc-JrDLc bgaREO thumbnailWrapper"><div class="sc-hCPjZK gAaMvB border "></div><img alt="D. E. Shaw employee." src="/img/video-images/icons/de-shaw-657781310.6e57cd6aa8.jpg" class="sc-fXSgeo lgwBdZ thumbnail"/><div class="sc-Nxspf gyQLGP playButton"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" style="margin-left:-2px"><polygon points="4 0 36 20 4 40 4 0"></polygon></svg></div></div></button><button data-video-id="657783083.7c076d8143" class="sc-fjvvzt keAAAN VideoListThumbnail  " aria-label="play video: D. E. Shaw employee."><div class="sc-JrDLc bgaREO thumbnailWrapper"><div class="sc-hCPjZK gAaMvB border "></div><img alt="D. E. Shaw employee." src="/img/video-images/icons/de-shaw-657783083.7c076d8143.jpg" class="sc-fXSgeo lgwBdZ thumbnail"/><div class="sc-Nxspf gyQLGP playButton"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" style="margin-left:-2px"><polygon points="4 0 36 20 4 40 4 0"></polygon></svg></div></div></button></div></li><li class="sc-lcIPJg inzaBa listItem    "><div class="sc-tagGq lakcSQ VideoListTextsContainer "><span class="sc-kdBSHD bIwAbd VideoListCount ">4<!-- --> video<!-- -->s</span><h3 class="sc-dCFHLb gvhOgC VideoListTitle "><span>Culture & Colleagues:</span></h3></div><div class="sc-esYiGF coZsKi VideoListThumbnailContainer"><button data-video-id="657780741.98e16af892" class="sc-fjvvzt keAAAN VideoListThumbnail  " aria-label="play video: D. E. Shaw employee."><div class="sc-JrDLc bgaR