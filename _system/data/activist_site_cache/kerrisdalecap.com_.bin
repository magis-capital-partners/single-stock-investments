turn dropDown(3423,jQuery(this));"><a href="javascript:void(0)" >Investors</a> <i id="ddu" class="ddown">&nbsp;</i><ul id="ul_3423" style="display:none" class="responsive-submenu"><li onClick="return dropDown(6472,jQuery(this));"><a href="https://kerrisdalecap.com/products">Products</a><li onClick="return dropDown(7501,jQuery(this));"><a target="_blank" href="https://onedoc.bridgeportft.com/signin" >Investor Statements</a><li onClick="return dropDown(3441,jQuery(this));"><a href="https://www.sscfundservices.com/login.aspx" >SS&C Administrator Portal</a></ul></li><li onClick="return dropDown(3415,jQuery(this));"><a href="https://kerrisdalecap.com/#contact-us">Contact Us</a></ul></div><section><div id="welcome"><h1 class="welcome-h1">Welcome to Kerrisdale Capital</h1><h2 class="welcome-h2">A research-oriented investment firm</h2><div class="welcome-subscribe"> <a class="subscribe-button" href="/subscribe">SUBSCRIBE</a></div></div></section><section><div id="recent-blog"> <span id="blog">&nbsp;</span> <span id="blogs">&nbsp;</span><h1 class="recent-blog-h2">Recent Posts</h1><div class="recent-blog-hr"></div><div class="recent-blog-posts"><div class="recent-blog-post-col"> <a href="/blog" style="text-decoration:none"><div class="post-header"><h2>Investments</h2><p class="post-header-description"> Initiating research coverage on long and short investments</p></div><div class="post-body"><div class="post-body-info"><h2>Regal Rexnord</h2><p class="post-body-description">Data Centers. Robotics. AI. Oh My!</p></div><div class="post-body-divider"></div><div class="post-body-date"><div class="post-body-month">June</div><div class="post-body-day">30</div><div class="post-body-year">2026</div></div></div> </a><div class="post-footer"> <a href="/blog" class="css3-button">VIEW MORE</a></div></div><div class="recent-blog-post-col"> <a href="/commentary" style="text-decoration:none"><div class="post-header"><h2>Commentary</h2><p class="post-header-description"> Company updates, market commentary, case studies and other topics we consider worth discussing</p></div><div class="post-body"><div class="post-body-info"><h2>ACMR – Letter to CEO and Board</h2><p class="post-body-description">Shareholder letter</p></div><div class="post-body-divider"></div><div class="post-body-date"><div class="post-body-month">April</div><div class="post-body-day">22</div><div class="post-body-year">2026</div></div></div> </a><div class="post-footer"> <a href="/commentary" class="css3-button">VIEW MORE</a></div></div></div></div></section><section class="mot-section"><div id="meet-our-team"><div class="our-team-header"><div class="team-detail"><a name="the-firm"></a><h1>The Firm</h1><div class="team-detail-divider" ></div><div class="team-detail-slogan"><div style="text-align: center;">Kerrisdale Capital is an investment management firm.</div><br /><div style="text-align: center;">We invest in public securities.</div></div><div class="team-people"><div class="person-block"><div class="person-image image1"><div class="person-bg"></div><a href="https://kerrisdalecap.com/firm/sahm-adrangi/" target="_blank"><img width="159" height="159" src="https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Sahm1.jpg" class="attachment-medium size-medium wp-post-image" alt="" decoding="async" loading="lazy" srcset="https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Sahm1.jpg 159w, https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Sahm1-150x150.jpg 150w" sizes="auto, (max-width: 159px) 100vw, 159px" /></a></div><div class="person-info"><div class="person-name"><a href="https://kerrisdalecap.com/firm/sahm-adrangi/" target="_blank">Sahm Adrangi</a></div><div class="person-title">Chief Investment Officer</div></div></div><div class="person-block"><div class="person-image image2"><div class="person-bg"></div><a href="https://kerrisdalecap.com/firm/edward-gu/" target="_blank"><img width="159" height="159" src="https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Edward.jpg" class="attachment-medium size-medium wp-post-image" alt="" decoding="async" loading="lazy" srcset="https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Edward.jpg 159w, https://www.kerrisdalecap.com/wp-content/uploads/2014/08/Edward-150x150.jpg 150w" sizes="auto, (max-width: 159px) 100vw, 159px" /></a></div><div class="person-info"><div class="person-name"><a href="https://kerrisdalecap.com/firm/edward-gu/" target="_blank">Edward Gu</a></div><div class="person-title">Chief Financial Officer</div></div></div><div class="person-block"><div class="person-image image3"><div class="person-bg"></div><a href="https://kerrisdalecap.com/firm/peter-baer/" target="_blank"><img width="159" height="159" src="https://www.kerrisdalecap.com/wp-content/uploads/2016/03/Peter-Baer.jpg" class="attachment-medium size-medium wp-post-image" alt="Peter Baer" decoding="async" loading="lazy" srcset="https://www.kerrisdalecap.com/wp-content/uploads/2016/03/Peter-Baer.jpg 159w, https://www.kerrisdalecap.com/wp-content/uploads/2016/03/Peter-Baer-150x150.jpg 150w" sizes="auto, (max-width: 159px) 100vw, 159px" /></a></div><div class="person-info"><div class="person-name"><a href="https://kerrisdalecap.com/firm/peter-baer/" target="_blank">Peter Baer</a></div><div class="person-title">Head of Marketing & Investor Relations</div></div></div></div></div></div></div></section><section id="investors"><div id="investor-login-area"><div class="inverstor_heading"><h1>Investor Login</h1><div class="investor-hr-divider"></div></div><div class="investor-panel"><div class="login-left"><form id="lgform" name="loginform" method="post" action=" https://kerrisdalecap.com/wp-login.php"> <input id="home-login" type="hidden" name="wp-submit" value="Login"><div> <input name="log" type="text" value="Username" onclick="this.value='';" onfocus="this.select()" onblur="this.value=!this.value?'Username':this.value;"></div><div> <input name="pwd" type="password" value="Password" onclick="this.value='';" onfocus="t