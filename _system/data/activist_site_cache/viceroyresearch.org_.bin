    .logos-scroller svg { fill: #404041 !important; opacity: 0.6; }
    
    .logos-scroller svg {
        max-width: 140px;
        max-height: 40px;
        margin: 0 2rem;
    }

    .marquee {
        animation: scrolling calc(var(--marquee-time) * 2) linear infinite;
    }

    .marquee:hover {
        animation-play-state: paused;
    }

    @keyframes scrolling {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-1 * var(--marquee-width))); }
    }

    .marquee:hover {
        animation-play-state: paused;
    }
