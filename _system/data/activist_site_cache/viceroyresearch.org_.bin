        <script>
            window.addEventListener('scroll', function loadRecaptchaOnScroll() {
                var script = document.createElement('script');
                script.src = 'https://www.google.com/recaptcha/api.js?render=';
                script.defer = true;
                document.body.appendChild(script);

                window.removeEventListener('scroll', loadRecaptchaOnScroll);
            });
        </script>

        
        <script>
            function disclaimerApp() {
                return {
                    // Navigation and scroll state
                    navOpen: false,
                    scrolled: false,
                    
                    // Disclaimer state
                    showModal: false,
                    disclaimerAgreed: false,
                    isAccepted: false,
                    
                    init() {
                        // Check sessionStorage on page load
                        this.isAccepted = sessionStorage.getItem('disclaimerAccepted') === 'true';
                        if (!this.isAccepted) {
                            this.showModal = true;
                            document.body.style.overflow = 'hidden';
                        }
                    },
                    
                    acceptDisclaimer() {
                        sessionStorage.setItem('disclaimerAccepted', 'true');
                        this.isAccepted = true;
                        this.showModal = false;
                        document.body.style.overflow = '';
                    },
                    
                    declineDisclaimer() {
                        window.location.href = 'https://google.com';
                    },
                    
                    reopenDisclaimer() {
                        this.showModal = true;
                        document.body.style.overflow = 'hidden';
                    }
                };
            }
        </script>

