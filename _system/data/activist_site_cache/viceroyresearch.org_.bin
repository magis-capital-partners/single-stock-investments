<script>
    function menu() {
        return {
            show: null,
            desktopMenu: window.matchMedia("(min-width: 1024px)").matches,
            trigger: {
                timeoutId: null,
                ['@mouseleave']() {
                    console.log('mouseleave')
                    if (this.desktopMenu) {
                        this.timeoutId = setTimeout(() => {
                            this.show = null;
                            this.$dispatch('close', this.$el.dataset.index);
                        }, 1500);
                    }
                },
                ['@mouseenter']() {
                    if (this.desktopMenu && this.timeoutId) {
                        clearTimeout(this.timeoutId);
                        this.timeoutId = null;
                    }

                    if (this.desktopMenu && !this.show) {
                        this.show = this.$el.dataset.index;
                        this.$dispatch('close', this.$el.dataset.index);
                    }
                },
                ['@close.window']($event) {
                    if ($event.detail != this.$el.dataset.index) {
                        this.show = null;
                    }
                },
                ['@click.away']() {
                    this.show = null;
                    clearTimeout(this.timeoutId);
                },
                ['@resize.window']() {
                    clearTimeout(this.resizeTimeout);
                    this.resizeTimeout = setTimeout(() => {
                        this.navOpen = false;
                        this.$dispatch('close', this.$el.dataset.index);
                        this.desktopMenu = window.matchMedia("(min-width: 1024px)").matches;
                    }, 200); // 200 ms
                },
            }
        }
    }
</script>
